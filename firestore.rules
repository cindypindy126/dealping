rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 카테고리 — 누구나 읽기, 쓰기 불가 (어드민은 Firebase Console 또는 Admin SDK로)
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // 가맹점 — 누구나 읽기
    match /merchants/{merchantId} {
      allow read: if true;
      allow write: if false;
    }

    // 카드/통신사 (혜택 제공자) — 누구나 읽기
    match /benefit_providers/{providerId} {
      allow read: if true;
      allow write: if false;

      // 혜택 서브컬렉션
      match /benefits/{benefitId} {
        allow read: if true;
        allow write: if false;
      }

      // 전월실적 구간 서브컬렉션
      match /tiers/{tierId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // 사용자 데이터 — 본인만 읽기/쓰기
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /my_providers/{providerId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
